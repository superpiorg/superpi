{
  "name": "superpi",
  "version": "0.1.0",
  "description": "A Codex-Desktop-style worktree + terminal manager for oh-my-pi",
  "private": true,
  "author": "mattia",
  "main": "./out/main/index.js",
  "bin": {
    "superpi": "bin/superpi.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "esbuild scripts/smoke-test.ts --bundle --platform=node --format=cjs --outfile=out/.smoke.cjs --log-level=warning && node out/.smoke.cjs",
    "postinstall": "electron-builder install-app-deps",
    "build:dist": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "dev.superpi.app",
    "productName": "superpi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/monitor.ts",
        "to": "monitor.ts"
      }
    ]
  }
}
